.form-textarea{min-height:100px;resize:vertical;line-height:1.6}
.form-submit{width:100%;margin-top:1.5rem;padding:1rem 2rem;background:var(--accent);border:none;border-radius:50px;color:#fff;font-family:var(--font-head);font-size:1rem;font-weight:800;letter-spacing:0.02em;cursor:none;transition:transform 0.42s var(--ease-premium),box-shadow 0.35s ease,background 0.35s ease;box-shadow:0 4px 20px rgba(21,101,192,0.3);position:relative;overflow:hidden}
.form-submit::before{content:'';position:absolute;top:-45%;left:-35%;width:32%;height:190%;background:linear-gradient(115deg,transparent,rgba(255,255,255,0.45),transparent);transform:translateX(-140%) rotate(12deg);transition:transform 0.78s var(--ease-premium)}
.form-submit::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.12),transparent);opacity:0;transition:opacity 0.3s}
.form-submit:hover{transform:translateY(-4px);box-shadow:0 14px 42px rgba(21,101,192,0.46),0 0 0 6px rgba(21,101,192,0.06)}
.form-submit:hover::before{transform:translateX(520%) rotate(12deg)}
.form-submit:hover::after{opacity:1}
.form-privacy{text-align:center;font-size:0.75rem;color:var(--muted2);margin-top:1rem}

/* MAP */
.map-section{background:var(--bg-deep)}
.map-container{border-radius:20px;overflow:hidden;border:1.5px solid var(--border2);position:relative;height:440px;margin-top:3rem;transition:transform 0.48s var(--ease-premium),box-shadow 0.4s ease,border-color 0.35s ease;box-shadow:0 4px 32px var(--shadow)}
.map-container::after{content:'';position:absolute;inset:0;border-radius:inherit;box-shadow:inset 0 0 0 1px rgba(255,255,255,0.45);pointer-events:none;opacity:0;transition:opacity 0.35s ease}
