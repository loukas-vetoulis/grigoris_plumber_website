.booking-emergency-card::before{content:'';position:absolute;left:0;top:1rem;bottom:1rem;width:3px;border-radius:999px;background:linear-gradient(180deg,#90caf9,#fff,rgba(144,202,249,0.4))}
.booking-emergency-card:hover{transform:translateY(-4px);background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.26);box-shadow:0 18px 42px rgba(3,35,82,0.18),inset 0 1px 0 rgba(255,255,255,0.18)}
