<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Πιπεράκης Ματθαίος | Υδραυλικές Εγκαταστάσεις Ρέθυμνο</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  /* White / Blue / Light-Blue premium system */
  --navy:#f0f7ff;
  --navy2:#e8f4fd;
  --navy3:#daeef9;
  --bg-deep:#f8fbff;
  --surface:#ffffff;
  --surface2:#eef6fc;
  --accent:#1565c0;
  --accent2:#1976d2;
  --accent3:#42a5f5;
  --accent-light:#90caf9;
  --accent-xlight:#e3f2fd;
  --gold:#f59e0b;
  --gold2:#fbbf24;
  --white:#1a2744;
  --muted:#5d7a96;
  --muted2:#8aa8c0;
  --border:rgba(21,101,192,0.12);
  --border2:rgba(21,101,192,0.22);
  --shadow:rgba(21,101,192,0.08);
  --ease-premium:cubic-bezier(0.16,1,0.3,1);
  --ease-smooth:cubic-bezier(0.22,1,0.36,1);
  --hover-shadow:0 18px 54px rgba(21,101,192,0.16);
  --hover-ring:0 0 0 6px rgba(21,101,192,0.055);
  --font-head:'Outfit',sans-serif;
  --font-body:'Plus Jakarta Sans',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg-deep);color:var(--white);font-family:var(--font-body);overflow-x:hidden;cursor:none}

/* CUSTOM CURSOR */
#cursor{position:fixed;width:12px;height:12px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform 0.1s,width 0.3s,height 0.3s,opacity 0.3s}
#cursor-ring{position:fixed;width:40px;height:40px;border:1.5px solid rgba(21,101,192,0.35);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:transform 0.15s ease-out,width 0.3s,height 0.3s,opacity 0.3s}
body:hover #cursor{opacity:1}

/* PREMIUM INTERACTION SYSTEM */
:where(a,button,.service-card,.testimonial-card,.map-info-item,.pipe-node,.cert-badge,.process-step,.trust-item,.stat-item,.booking-point,.booking-info,.booking-emergency-card,.booking-form,.map-container,.about-card,.phone-link,.lang-btn){-webkit-tap-highlight-color:transparent}
:where(a,button,input,select,textarea):focus-visible{outline:2px solid rgba(21,101,192,0.65);outline-offset:4px}
:where(.service-card,.testimonial-card,.map-info-item,.pipe-node,.process-step,.stat-item,.booking-point,.booking-info,.booking-emergency-card,.about-card,.booking-form,.map-container){backface-visibility:hidden;transform-style:preserve-3d}

/* HEADER */
.scroll-progress{position:fixed;top:0;left:0;width:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent3),var(--accent-light));z-index:1000;box-shadow:0 0 16px rgba(66,165,245,0.34);transition:width 0.12s linear}
header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  z-index:100;
  padding:1.2rem 4rem;
  display:flex;
  align-items:center;
  justify-content:space-between;
  background:rgba(248,251,255,0.82);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
  transition:padding 0.4s ease,background 0.4s ease,box-shadow 0.4s ease;
}

header.scrolled{
  padding:0.8rem 4rem;
  background:rgba(255,255,255,0.97);
  box-shadow:0 2px 24px var(--shadow);
}

.logo{
  display:flex;
  align-items:center;
  gap:1.05rem;
  color:var(--white);
  font-family:var(--font-head);
  font-size:1.4rem;
  font-weight:800;
  letter-spacing:-0.02em;
  text-decoration:none;
  transition:transform 0.35s var(--ease-premium),color 0.3s ease;
}
.logo:hover{transform:translateY(-2px)}

.logo-mark{
  width:122px;
  height:76px;
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  background:transparent;
  isolation:isolate;
  animation:logo-float 4s ease-in-out infinite;
}

.logo-mark img{
  display:block;
  width:100%;
  height:100%;
  max-width:none;
  object-fit:contain;
  object-position:center;
  background:transparent;
  filter:drop-shadow(0 10px 18px rgba(21,101,192,0.14));
  transition:transform 0.35s ease,filter 0.35s ease,opacity 0.35s ease;
}

.logo:hover .logo-mark img{
  transform:translateY(-4px) scale(1.04);
  filter:drop-shadow(0 16px 24px rgba(21,101,192,0.24));
}

.logo-text{
  display:flex;
  flex-direction:column;
  line-height:1.02;
}

.logo-text strong{
  font-size:1rem;
  font-weight:800;
  color:var(--white);
  transition:color 0.3s ease;
}

.logo-text span{
  font-size:0.68rem;
  font-weight:700;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--accent);
  transition:color 0.3s ease;
}
.logo:hover .logo-text strong{color:var(--accent)}
.logo:hover .logo-text span{color:var(--accent2)}

@keyframes logo-float{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-6px)}
}

nav{
  display:flex;
  align-items:center;
  gap:2.5rem;
}

nav a{
  position:relative;
  isolation:isolate;
  font-size:0.82rem;
  font-weight:600;
  letter-spacing:0.07em;
  text-transform:uppercase;
  color:var(--muted);
  text-decoration:none;
  padding:0.5rem 0;
  transition:color 0.3s ease,transform 0.35s var(--ease-premium);
}

nav a::before{
  content:'';
  position:absolute;
  left:50%;
  top:50%;
  width:calc(100% + 1.5rem);
  height:2rem;
  border-radius:999px;
  background:rgba(21,101,192,0.055);
  transform:translate(-50%,-50%) scaleX(0.7);
  opacity:0;
  transition:opacity 0.35s ease,transform 0.35s var(--ease-premium);
  z-index:-1;
}

nav a::after{
  content:'';
  position:absolute;
  left:0;
  bottom:-4px;
  width:0;
  height:1.5px;
  background:var(--accent);
  transition:width 0.3s ease;
}

nav a:hover{
  color:var(--accent);
  transform:translateY(-2px);
}

nav a:hover::after{
  width:100%;
}

nav a:hover::before{
  opacity:1;
  transform:translate(-50%,-50%) scaleX(1);
}

.header-right{
  display:flex;
  align-items:center;
  gap:1.5rem;
}

/* STATUS BADGE */
.status-badge{display:flex;align-items:center;gap:0.5rem;padding:0.35rem 1rem;border-radius:50px;border:1px solid var(--border2);background:rgba(21,101,192,0.05);font-size:0.75rem;font-weight:600;letter-spacing:0.04em;transition:transform 0.35s var(--ease-premium),box-shadow 0.35s ease,background 0.35s ease,border-color 0.35s ease}
.status-badge:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(21,101,192,0.1)}
.status-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.status-dot.open{background:#16a34a;box-shadow:0 0 6px #16a34a,0 0 12px rgba(22,163,74,0.3);animation:pulse-green 2s infinite}
.status-dot.closed{background:#dc2626;box-shadow:0 0 6px #dc2626}
@keyframes pulse-green{0%,100%{box-shadow:0 0 6px #16a34a,0 0 12px rgba(22,163,74,0.3)}50%{box-shadow:0 0 10px #16a34a,0 0 20px rgba(22,163,74,0.5)}}
.status-text.open{color:#15803d}
.status-text.closed{color:#dc2626}

/* LANG TOGGLE */
.lang-toggle{display:flex;align-items:center;background:var(--accent-xlight);border:1px solid var(--border);border-radius:50px;padding:3px;gap:2px;transition:transform 0.35s var(--ease-premium),box-shadow 0.35s ease}
.lang-toggle:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(21,101,192,0.12)}
.lang-btn{padding:0.25rem 0.7rem;border-radius:50px;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;border:none;cursor:none;transition:transform 0.3s var(--ease-premium),background 0.3s ease,color 0.3s ease,box-shadow 0.3s ease;color:var(--muted);background:transparent}
.lang-btn:hover{transform:translateY(-1px);color:var(--accent);background:rgba(255,255,255,0.66)}
.lang-btn.active{background:var(--accent);color:#fff;box-shadow:0 2px 12px rgba(21,101,192,0.3)}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:8rem 4rem 4rem;z-index:1;background:linear-gradient(160deg,#f0f7ff 0%,#e3f2fd 40%,#f8fbff 100%);overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 74% 42%,rgba(66,165,245,0.18),transparent 34%),linear-gradient(120deg,rgba(255,255,255,0.72),transparent 48%);pointer-events:none}
.hero-shell{width:min(1200px,100%);display:grid;grid-template-columns:minmax(0,1fr) minmax(340px,0.82fr);gap:4.5rem;align-items:center;position:relative;z-index:1}
.hero-inner{max-width:680px;text-align:left}
.hero-eyebrow{display:inline-flex;align-items:center;gap:0.75rem;font-size:0.69rem;font-weight:900;letter-spacing:0.2em;text-transform:uppercase;color:#0d47a1;margin-bottom:2rem;padding:0.72rem 1.15rem;border:1px solid rgba(21,101,192,0.16);border-radius:999px;background:linear-gradient(135deg,rgba(255,255,255,0.86),rgba(227,242,253,0.58));box-shadow:0 12px 34px rgba(21,101,192,0.1),inset 0 1px 0 rgba(255,255,255,0.95);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);position:relative;overflow:hidden;isolation:isolate;transition:transform 0.4s var(--ease-premium),box-shadow 0.35s ease,background 0.35s ease,border-color 0.35s ease,color 0.35s ease}
.hero-eyebrow::before{content:'';width:8px;height:8px;background:radial-gradient(circle,#42a5f5 0 36%,#1565c0 37% 100%);border-radius:50%;box-shadow:0 0 0 5px rgba(66,165,245,0.12),0 0 18px rgba(21,101,192,0.36);flex:0 0 auto;animation:eyebrow-pulse 2.6s ease-in-out infinite}
.hero-eyebrow::after{content:'';position:absolute;top:0;bottom:0;left:-35%;width:28%;background:linear-gradient(105deg,transparent,rgba(255,255,255,0.58),transparent);transform:skewX(-18deg);opacity:0;transition:transform 0.72s var(--ease-premium),opacity 0.35s ease;z-index:-1}
.hero-eyebrow span{position:relative;line-height:1.25}
.hero-eyebrow:hover{transform:translateY(-4px);background:rgba(255,255,255,0.88);border-color:rgba(21,101,192,0.28);box-shadow:0 18px 46px rgba(21,101,192,0.16),inset 0 1px 0 rgba(255,255,255,0.96);color:var(--accent)}
.hero-eyebrow:hover::after{opacity:1;transform:translateX(520%) skewX(-18deg)}
@keyframes eyebrow-pulse{0%,100%{transform:scale(1);box-shadow:0 0 0 5px rgba(66,165,245,0.12),0 0 18px rgba(21,101,192,0.28)}50%{transform:scale(1.18);box-shadow:0 0 0 8px rgba(66,165,245,0.08),0 0 24px rgba(21,101,192,0.42)}}
.hero h1{font-family:var(--font-head);font-size:clamp(2.8rem,6.5vw,5.2rem);font-weight:900;line-height:1.05;letter-spacing:-0.03em;margin-bottom:1.5rem;color:var(--white)}
.hero h1 em{font-style:normal;color:var(--accent)}
.hero-sub{font-size:1.05rem;font-weight:400;color:var(--muted);line-height:1.85;max-width:600px;margin:0 0 3rem}
.hero-ctas{display:flex;align-items:center;justify-content:flex-start;gap:1rem;flex-wrap:wrap}
.btn-primary{padding:0.9rem 2.2rem;background:var(--accent);color:#fff;font-family:var(--font-body);font-weight:700;font-size:0.9rem;letter-spacing:0.02em;border:none;border-radius:50px;cursor:none;transition:transform 0.42s var(--ease-premium),box-shadow 0.35s ease,background 0.35s ease,color 0.35s ease;box-shadow:0 4px 20px rgba(21,101,192,0.28),0 0 0 0 rgba(21,101,192,0);position:relative;overflow:hidden}
.btn-primary::before{content:'';position:absolute;top:-45%;left:-35%;width:32%;height:190%;background:linear-gradient(115deg,transparent,rgba(255,255,255,0.48),transparent);transform:translateX(-140%) rotate(12deg);transition:transform 0.75s var(--ease-premium)}
.btn-primary::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.18),transparent);opacity:0;transition:opacity 0.3s}
.btn-primary:hover{transform:translateY(-4px) scale(1.015);box-shadow:0 14px 42px rgba(21,101,192,0.42),var(--hover-ring)}
.btn-primary:hover::before{transform:translateX(520%) rotate(12deg)}
.btn-primary:hover::after{opacity:1}
.btn-primary:active,.btn-ghost:active,.form-submit:active,.phone-link:active{transform:translateY(-1px) scale(0.99)}
.btn-ghost{padding:0.9rem 2.2rem;background:transparent;color:var(--accent);font-family:var(--font-body);font-weight:600;font-size:0.9rem;letter-spacing:0.02em;border:1.5px solid var(--border2);border-radius:50px;cursor:none;transition:transform 0.42s var(--ease-premium),box-shadow 0.35s ease,border-color 0.35s ease,background 0.35s ease,color 0.35s ease;position:relative;overflow:hidden}
.btn-ghost::after{content:'';position:absolute;inset:0;background:linear-gradient(120deg,rgba(21,101,192,0.08),rgba(144,202,249,0.18),rgba(21,101,192,0.05));opacity:0;transform:translateX(-35%);transition:opacity 0.35s ease,transform 0.55s var(--ease-premium)}
.btn-ghost:hover{border-color:var(--accent);background:rgba(255,255,255,0.72);transform:translateY(-4px) scale(1.01);box-shadow:0 14px 36px rgba(21,101,192,0.14)}
.btn-ghost:hover::after{opacity:1;transform:translateX(0)}
.btn-primary::before,.btn-primary::after,.btn-ghost::after,.form-submit::before,.form-submit::after,.phone-link::after{pointer-events:none}
.hero-trust{display:flex;align-items:center;justify-content:flex-start;gap:1rem;margin-top:3.2rem;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;font-weight:500;color:var(--muted);padding:0.45rem 0.7rem;border-radius:999px;transition:transform 0.35s var(--ease-premium),background 0.35s ease,box-shadow 0.35s ease,color 0.35s ease}
.trust-item strong{color:var(--accent);font-weight:800;transition:transform 0.35s var(--ease-premium),color 0.35s ease}
.trust-item:hover{transform:translateY(-3px);background:rgba(255,255,255,0.62);box-shadow:0 12px 28px rgba(21,101,192,0.1);color:var(--white)}
.trust-item:hover strong{transform:scale(1.08);color:#0d47a1}
.trust-sep{width:1px;height:20px;background:var(--border2)}

.hero-visual{position:relative;min-height:520px;display:flex;align-items:center;justify-content:center;isolation:isolate}
.hero-visual-card{width:min(440px,100%);aspect-ratio:0.86;border:1px solid rgba(21,101,192,0.16);border-radius:30px;background:linear-gradient(145deg,rgba(255,255,255,0.88),rgba(227,242,253,0.62));box-shadow:0 26px 80px rgba(21,101,192,0.18),inset 0 1px 0 rgba(255,255,255,0.92);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;transform:translateY(0);transition:transform 0.55s var(--ease-premium),box-shadow 0.45s ease,border-color 0.35s ease}
.hero-visual-card::before{content:'';position:absolute;inset:10%;border-radius:50%;background:radial-gradient(circle,rgba(66,165,245,0.2),transparent 66%);filter:blur(8px);animation:hero-pulse 5.5s ease-in-out infinite}
.hero-visual-card::after{content:'';position:absolute;inset:0;background:linear-gradient(115deg,transparent 22%,rgba(255,255,255,0.48) 48%,transparent 72%);transform:translateX(-110%);animation:hero-sheen 6s var(--ease-premium) infinite}
.hero-visual-card:hover{transform:translateY(-10px) rotate(-1deg);border-color:rgba(21,101,192,0.28);box-shadow:0 36px 96px rgba(21,101,192,0.24),inset 0 1px 0 rgba(255,255,255,0.94)}
.hero-visual-logo{width:78%;height:auto;position:relative;z-index:2;filter:drop-shadow(0 22px 32px rgba(13,71,161,0.22));animation:hero-logo-float 5s ease-in-out infinite}
.hero-orbit{position:absolute;border:1px solid rgba(21,101,192,0.14);border-radius:50%;z-index:1}
.hero-orbit.one{width:82%;aspect-ratio:1;animation:orbit-spin 18s linear infinite}
.hero-orbit.two{width:58%;aspect-ratio:1;animation:orbit-spin 14s linear infinite reverse}
.hero-proof-card{position:absolute;right:-0.5rem;bottom:3rem;z-index:4;padding:1rem 1.2rem;border-radius:18px;background:rgba(255,255,255,0.86);border:1px solid rgba(21,101,192,0.14);box-shadow:0 18px 46px rgba(21,101,192,0.16);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);transition:transform 0.45s var(--ease-premium),box-shadow 0.35s ease}
.hero-proof-card:hover{transform:translateY(-6px);box-shadow:0 24px 58px rgba(21,101,192,0.22)}
.hero-proof-kicker{font-size:0.68rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.25rem}
.hero-proof-main{font-family:var(--font-head);font-size:1.35rem;font-weight:900;color:var(--accent);line-height:1}
.hero-proof-note{font-size:0.75rem;color:var(--muted);margin-top:0.25rem}
@keyframes hero-logo-float{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-10px) scale(1.02)}}
@keyframes hero-pulse{0%,100%{opacity:0.55;transform:scale(0.94)}50%{opacity:1;transform:scale(1.08)}}
@keyframes hero-sheen{0%,48%{transform:translateX(-115%)}68%,100%{transform:translateX(115%)}}
@keyframes orbit-spin{to{transform:rotate(360deg)}}

/* SCROLL INDICATOR */
.scroll-ind{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted2)}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--accent),transparent);animation:scroll-anim 2s ease-in-out infinite}
@keyframes scroll-anim{0%{opacity:0;transform:scaleY(0);transform-origin:top}50%{opacity:1;transform:scaleY(1)}100%{opacity:0;transform:scaleY(1);transform-origin:bottom}}

/* STATS BAR */
.stats-bar{position:relative;z-index:1;background:var(--accent);border-top:none;border-bottom:none;backdrop-filter:none;padding:2.5rem 4rem}
.stats-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center}
.stat-item{padding:0 1rem;border-radius:16px;transition:transform 0.38s var(--ease-premium),background 0.35s ease,box-shadow 0.35s ease}
.stat-item:hover{transform:translateY(-5px);background:rgba(255,255,255,0.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,0.16)}
.stat-num{font-family:var(--font-head);font-size:2.5rem;font-weight:900;color:#ffffff;letter-spacing:-0.03em;transition:transform 0.38s var(--ease-premium),text-shadow 0.35s ease}
.stat-item:hover .stat-num{transform:scale(1.06);text-shadow:0 10px 28px rgba(255,255,255,0.22)}
.stat-label{font-size:0.78rem;color:rgba(255,255,255,0.75);letter-spacing:0.05em;margin-top:0.25rem;font-weight:500;transition:color 0.35s ease}
.stat-item:hover .stat-label{color:rgba(255,255,255,0.92)}

/* TRUST STRIP */
.trust-strip{position:relative;z-index:1;padding:2.2rem 4rem;background:#fff;border-bottom:1px solid var(--border)}
.trust-strip-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:1rem}
.trust-card{position:relative;overflow:hidden;border:1px solid var(--border);border-radius:16px;background:linear-gradient(145deg,#fff,#f4f9ff);padding:1.2rem 1rem;box-shadow:0 4px 22px rgba(21,101,192,0.06);transition:transform 0.42s var(--ease-premium),box-shadow 0.35s ease,border-color 0.35s ease}
.trust-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(21,101,192,0.07),transparent 55%);opacity:0;transition:opacity 0.35s ease}
.trust-card:hover{transform:translateY(-6px);border-color:rgba(21,101,192,0.28);box-shadow:0 16px 42px rgba(21,101,192,0.12)}
.trust-card:hover::before{opacity:1}
.trust-card-icon{font-size:1.2rem;margin-bottom:0.7rem;position:relative}
.trust-card-title{font-family:var(--font-head);font-size:0.9rem;font-weight:800;color:var(--white);margin-bottom:0.3rem;position:relative}
.trust-card-copy{font-size:0.76rem;line-height:1.55;color:var(--muted);position:relative}

/* SECTION WRAPPER */
section{position:relative;z-index:1;padding:7rem 4rem}
.section-eyebrow{font-size:0.72rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem;display:flex;align-items:center;gap:0.6rem}
.section-eyebrow::before{content:'';width:24px;height:1.5px;background:var(--accent)}
.section-title{font-family:var(--font-head);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-0.03em;line-height:1.1;margin-bottom:1.2rem;color:var(--white)}
.section-sub{font-size:1rem;color:var(--muted);line-height:1.85;max-width:560px}
.section-inner{max-width:1200px;margin:0 auto}

/* ABOUT / INTRO */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center}
.about-visual{position:relative}
.about-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:3rem;position:relative;overflow:hidden;box-shadow:0 4px 32px var(--shadow);transition:transform 0.45s var(--ease-premium),box-shadow 0.4s ease,border-color 0.35s ease}
.about-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--accent),var(--accent-light),transparent)}
.about-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(66,165,245,0.11),transparent 55%);opacity:0;transition:opacity 0.4s ease;pointer-events:none}
.about-card:hover{transform:translateY(-6px);border-color:rgba(21,101,192,0.28);box-shadow:var(--hover-shadow)}
.about-card:hover::after{opacity:1}
.expertise-label{font-size:0.78rem;color:var(--muted);letter-spacing:0.11em;text-transform:uppercase;margin-bottom:1.2rem;font-weight:800;position:relative}
.pipe-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;margin-top:2rem}
.pipe-node{min-height:128px;background:linear-gradient(155deg,#ffffff 0%,#edf7ff 100%);border:1px solid rgba(21,101,192,0.13);border-radius:18px;padding:1.15rem 0.85rem;text-align:center;transition:transform 0.42s var(--ease-premium),background 0.35s ease,border-color 0.35s ease,box-shadow 0.35s ease;position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.7rem;box-shadow:0 6px 22px rgba(21,101,192,0.06),inset 0 1px 0 rgba(255,255,255,0.84)}
.pipe-node::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(66,165,245,0.18),transparent 62%),linear-gradient(135deg,rgba(255,255,255,0.7),transparent 46%);opacity:0;transform:translateY(18px);transition:opacity 0.35s ease,transform 0.45s var(--ease-premium)}
.pipe-node::after{content:'';position:absolute;left:18%;right:18%;bottom:0;height:3px;border-radius:999px 999px 0 0;background:linear-gradient(90deg,transparent,var(--accent3),var(--accent),transparent);transform:scaleX(0);transform-origin:center;transition:transform 0.45s var(--ease-premium)}
.pipe-node:hover{border-color:rgba(21,101,192,0.34);background:#fff;transform:translateY(-8px);box-shadow:0 18px 44px rgba(21,101,192,0.14),inset 0 1px 0 rgba(255,255,255,0.9)}
.pipe-node:hover::before{opacity:1;transform:translateY(0)}
.pipe-node:hover::after{transform:scaleX(1)}
.pipe-icon{width:42px;height:42px;border-radius:14px;background:rgba(21,101,192,0.07);border:1px solid rgba(21,101,192,0.12);display:flex;align-items:center;justify-content:center;color:var(--accent);position:relative;transition:transform 0.45s var(--ease-premium),background 0.35s ease,border-color 0.35s ease,box-shadow 0.35s ease}
.pipe-icon svg{width:22px;height:22px;stroke:currentColor;stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round}
.pipe-node:hover .pipe-icon{transform:translateY(-4px) scale(1.08);background:rgba(21,101,192,0.1);border-color:rgba(21,101,192,0.28);box-shadow:0 12px 26px rgba(21,101,192,0.14)}
.pipe-label{font-size:0.72rem;color:var(--muted);letter-spacing:0.04em;font-weight:800;line-height:1.25;position:relative;transition:color 0.35s ease,transform 0.35s var(--ease-premium);overflow-wrap:anywhere}
.pipe-node:hover .pipe-label{color:var(--white);transform:translateY(-1px)}
.cert-row{display:flex;gap:0.8rem;margin-top:1.5rem;flex-wrap:wrap}
.cert-badge{padding:0.35rem 1rem;border:1.5px solid var(--border2);border-radius:50px;font-size:0.72rem;font-weight:700;color:var(--accent);letter-spacing:0.06em;background:var(--accent-xlight);transition:transform 0.35s var(--ease-premium),box-shadow 0.35s ease,background 0.35s ease,border-color 0.35s ease}
.cert-badge:hover{transform:translateY(-3px);background:#fff;border-color:rgba(21,101,192,0.38);box-shadow:0 12px 26px rgba(21,101,192,0.12)}

/* SERVICES */
.services-bg{background:var(--surface2)}
.services-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:4rem;flex-wrap:wrap;gap:2rem}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.service-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:2.5rem;cursor:none;transition:transform 0.5s var(--ease-premium),box-shadow 0.4s ease,border-color 0.35s ease,background 0.35s ease;position:relative;overflow:hidden;box-shadow:0 2px 16px var(--shadow)}
.service-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background:radial-gradient(circle at 50% 0%,rgba(21,101,192,0.08),transparent 60%);opacity:0;transition:opacity 0.4s}
.service-card::after{content:'';position:absolute;top:-35%;left:-45%;width:38%;height:170%;background:linear-gradient(115deg,transparent,rgba(255,255,255,0.55),transparent);opacity:0;transform:translateX(-120%) rotate(14deg);transition:transform 0.8s var(--ease-premium),opacity 0.35s ease;pointer-events:none}
.service-card:hover{border-color:rgba(21,101,192,0.34);transform:translateY(-10px);box-shadow:0 22px 58px rgba(21,101,192,0.16)}
.service-card:hover::before{opacity:1}
.service-card:hover::after{opacity:1;transform:translateX(470%) rotate(14deg)}
.service-num{font-family:var(--font-head);font-size:3.5rem;font-weight:900;color:rgba(21,101,192,0.07);line-height:1;margin-bottom:1.5rem;letter-spacing:-0.04em;transition:color 0.4s}
.service-card:hover .service-num{color:rgba(21,101,192,0.16)}
.service-icon-wrap{width:48px;height:48px;border-radius:12px;background:var(--accent-xlight);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;font-size:1.2rem;transition:transform 0.48s var(--ease-premium),background 0.35s ease,border-color 0.35s ease,box-shadow 0.35s ease}
.service-card:hover .service-icon-wrap{background:rgba(21,101,192,0.15);border-color:var(--accent);box-shadow:0 0 18px rgba(21,101,192,0.2);transform:translateY(-4px) scale(1.08) rotate(-2deg)}
.service-title{font-family:var(--font-head);font-size:1.1rem;font-weight:700;margin-bottom:0.8rem;transition:color 0.3s;color:var(--white)}
.service-card:hover .service-title{color:var(--accent)}
.service-desc{font-size:0.88rem;color:var(--muted);line-height:1.75}
.service-link{display:inline-flex;align-items:center;gap:0.4rem;margin-top:1.5rem;font-size:0.8rem;font-weight:700;color:var(--accent);letter-spacing:0.04em;text-decoration:none;transition:gap 0.35s var(--ease-premium),transform 0.35s var(--ease-premium),color 0.3s ease}
.service-link:hover,.service-card:hover .service-link{gap:0.75rem;transform:translateX(2px);color:#0d47a1}
.service-meta{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1.35rem}
.service-pill{font-size:0.68rem;font-weight:800;letter-spacing:0.06em;text-transform:uppercase;color:var(--accent);padding:0.35rem 0.65rem;border-radius:999px;border:1px solid rgba(21,101,192,0.14);background:rgba(21,101,192,0.055);opacity:0;transform:translateY(8px);transition:opacity 0.35s ease,transform 0.42s var(--ease-premium),background 0.35s ease}
.service-card:hover .service-pill{opacity:1;transform:translateY(0)}
.service-card:hover .service-pill:nth-child(2){transition-delay:0.04s}
.service-card:hover .service-pill:nth-child(3){transition-delay:0.08s}

/* PROJECT SHOWCASE */
.projects-bg{background:var(--bg-deep)}
.projects-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3.5rem;gap:2rem;flex-wrap:wrap}
.project-grid{display:grid;grid-template-columns:1.1fr 0.9fr 0.9fr;gap:1.5rem}
.project-card{min-height:310px;border:1px solid var(--border);border-radius:22px;background:linear-gradient(145deg,#fff,#eef6fc);padding:2rem;position:relative;overflow:hidden;box-shadow:0 4px 28px rgba(21,101,192,0.08);transition:transform 0.5s var(--ease-premium),box-shadow 0.4s ease,border-color 0.35s ease}
.project-card.featured{grid-row:span 2;min-height:645px}
.project-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 75% 18%,rgba(66,165,245,0.2),transparent 34%),linear-gradient(135deg,rgba(21,101,192,0.07),transparent 48%);opacity:0.72;transition:opacity 0.4s ease}
.project-card::after{content:'';position:absolute;right:-3rem;bottom:-3rem;width:13rem;height:13rem;border-radius:50%;border:1px solid rgba(21,101,192,0.12);box-shadow:inset 0 0 0 24px rgba(21,101,192,0.035);transition:transform 0.55s var(--ease-premium)}
.project-card:hover{transform:translateY(-10px);border-color:rgba(21,101,192,0.28);box-shadow:0 24px 62px rgba(21,101,192,0.15)}
.project-card:hover::before{opacity:1}
.project-card:hover::after{transform:scale(1.12) rotate(12deg)}
.project-type{position:relative;font-size:0.68rem;font-weight:900;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);margin-bottom:1.1rem}
.project-title{position:relative;font-family:var(--font-head);font-size:1.35rem;font-weight:900;line-height:1.12;color:var(--white);margin-bottom:0.8rem}
.project-card.featured .project-title{font-size:2rem}
.project-copy{position:relative;color:var(--muted);font-size:0.9rem;line-height:1.75;max-width:31rem}
.project-metrics{position:absolute;left:2rem;right:2rem;bottom:2rem;display:flex;gap:0.8rem;flex-wrap:wrap;z-index:1}
.project-metric{padding:0.65rem 0.8rem;border-radius:14px;background:rgba(255,255,255,0.78);border:1px solid rgba(21,101,192,0.12);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
.project-metric strong{display:block;font-family:var(--font-head);font-size:1.05rem;color:var(--accent);line-height:1}
.project-metric span{display:block;font-size:0.68rem;color:var(--muted);margin-top:0.25rem}

/* PROCESS */
.process-grid{--process-gap:2rem;display:grid;grid-template-columns:repeat(4,1fr);gap:var(--process-gap);margin-top:4rem;position:relative;isolation:isolate;overflow:visible}
.process-step{text-align:center;position:relative;z-index:1;padding-top:0.1rem;--connector-start:42px;--connector-end:42px}
.process-step::before{content:'';position:absolute;top:27px;left:calc(50% + var(--connector-start));width:calc(100% + var(--process-gap) - var(--connector-start) - var(--connector-end));height:2px;border-radius:999px;background:linear-gradient(90deg,rgba(21,101,192,0),rgba(21,101,192,0.38) 18%,rgba(66,165,245,0.82) 52%,rgba(21,101,192,0.22) 86%,rgba(21,101,192,0));box-shadow:0 0 18px rgba(66,165,245,0.22);opacity:0;transform:scaleX(0);transform-origin:left;z-index:-1}
.process-step::after{content:'';position:absolute;top:19px;left:calc(50% + var(--connector-start));width:18px;height:18px;border-top:2px solid var(--accent);border-right:2px solid var(--accent);filter:drop-shadow(0 0 10px rgba(66,165,245,0.45));opacity:0;transform:translateX(-50%) rotate(45deg) scale(0.72);z-index:0}
.process-step:last-child::before,.process-step:last-child::after{display:none}
.process-step.visible::before{animation:process-connector-draw 0.95s cubic-bezier(0.16,1,0.3,1) both}
.process-step.visible::after{animation:process-arrow-flight 1.15s cubic-bezier(0.16,1,0.3,1) both}
.process-step.visible:nth-child(1)::before,.process-step.visible:nth-child(1)::after{animation-delay:0.28s}
.process-step.visible:nth-child(2)::before,.process-step.visible:nth-child(2)::after{animation-delay:0.46s}
.process-step.visible:nth-child(3)::before,.process-step.visible:nth-child(3)::after{animation-delay:0.64s}
.process-circle{width:56px;height:56px;border-radius:50%;background:linear-gradient(180deg,#ffffff 0%,#f4f9ff 100%);border:1.5px solid rgba(21,101,192,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-family:var(--font-head);font-weight:800;font-size:1rem;color:var(--accent);position:relative;transition:transform 0.45s cubic-bezier(0.16,1,0.3,1),border-color 0.35s ease,box-shadow 0.35s ease,background 0.35s ease,color 0.35s ease;box-shadow:0 10px 30px rgba(21,101,192,0.1),inset 0 1px 0 rgba(255,255,255,0.9);will-change:transform}
.process-circle::before{content:'';position:absolute;inset:-8px;border-radius:50%;background:radial-gradient(circle,rgba(66,165,245,0.26),rgba(66,165,245,0) 68%);opacity:0;transform:scale(0.72);transition:opacity 0.35s ease,transform 0.45s cubic-bezier(0.16,1,0.3,1);z-index:-1}
.process-circle::after{content:'';position:absolute;inset:-5px;border-radius:50%;border:1px solid transparent;background:linear-gradient(135deg,rgba(21,101,192,0.82),rgba(144,202,249,0.18),transparent) border-box;-webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;opacity:0;transform:scale(0.88);transition:opacity 0.35s ease,transform 0.45s cubic-bezier(0.16,1,0.3,1)}
.process-step.visible .process-circle{animation:process-bubble-in 0.72s cubic-bezier(0.18,1.35,0.32,1) backwards}
.process-step.visible:nth-child(1) .process-circle{animation-delay:0.02s}
.process-step.visible:nth-child(2) .process-circle{animation-delay:0.14s}
.process-step.visible:nth-child(3) .process-circle{animation-delay:0.26s}
.process-step.visible:nth-child(4) .process-circle{animation-delay:0.38s}
.process-step:hover .process-circle{background:linear-gradient(180deg,#ffffff 0%,#eaf5ff 100%);border-color:rgba(21,101,192,0.48);color:#0d47a1;transform:translateY(-6px) scale(1.08);box-shadow:0 18px 42px rgba(21,101,192,0.2),0 0 0 8px rgba(21,101,192,0.055),inset 0 1px 0 rgba(255,255,255,0.96)}
.process-step:hover .process-circle::before{opacity:1;transform:scale(1.1)}
.process-step:hover .process-circle::after{opacity:1;transform:scale(1)}
.process-step:hover::before{opacity:1;background:linear-gradient(90deg,rgba(21,101,192,0),rgba(21,101,192,0.56) 18%,rgba(66,165,245,0.95) 52%,rgba(21,101,192,0.34) 86%,rgba(21,101,192,0));box-shadow:0 0 24px rgba(66,165,245,0.32)}
.process-step.visible:hover::after{animation:process-arrow-hover 0.92s cubic-bezier(0.16,1,0.3,1) both}
.process-title{font-family:var(--font-head);font-size:1rem;font-weight:700;margin-bottom:0.5rem;color:var(--white);transition:color 0.3s ease,transform 0.35s cubic-bezier(0.16,1,0.3,1)}
.process-step:hover .process-title{color:var(--accent);transform:translateY(-2px)}
.process-desc{font-size:0.82rem;color:var(--muted);line-height:1.7}
@keyframes process-bubble-in{0%{opacity:0;transform:translateY(14px) scale(0.58)}58%{opacity:1;transform:translateY(-5px) scale(1.13)}78%{transform:translateY(2px) scale(0.97)}100%{opacity:1;transform:translateY(0) scale(1)}}
@keyframes process-connector-draw{0%{opacity:0;transform:scaleX(0)}18%{opacity:1}100%{opacity:1;transform:scaleX(1)}}
@keyframes process-arrow-flight{0%{left:calc(50% + var(--connector-start));opacity:0;transform:translateX(-50%) rotate(45deg) scale(0.72)}18%{opacity:1}82%{opacity:1}100%{left:calc(150% + var(--process-gap) - var(--connector-end));opacity:0;transform:translateX(-50%) rotate(45deg) scale(1)}}
@keyframes process-arrow-hover{0%{left:calc(50% + var(--connector-start));opacity:0;transform:translateX(-50%) rotate(45deg) scale(0.74)}20%{opacity:1}78%{opacity:1}100%{left:calc(150% + var(--process-gap) - var(--connector-end));opacity:0;transform:translateX(-50%) rotate(45deg) scale(1.04)}}
@media(prefers-reduced-motion:reduce){
  .process-step.visible .process-circle,.process-step.visible::before,.process-step.visible::after{animation:none}
  .process-step::before{opacity:1;transform:scaleX(1)}
  .process-step::after{display:none}
}

/* TESTIMONIALS */
.testimonials-bg{background:var(--surface2)}
.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:4rem}
.testimonial-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:2rem;transition:transform 0.48s var(--ease-premium),box-shadow 0.4s ease,border-color 0.35s ease;cursor:none;box-shadow:0 2px 16px var(--shadow);position:relative;overflow:hidden}
.testimonial-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(21,101,192,0.07),transparent 44%);opacity:0;transition:opacity 0.4s ease;pointer-events:none}
.testimonial-card:hover{border-color:rgba(21,101,192,0.34);transform:translateY(-8px);box-shadow:0 18px 48px rgba(21,101,192,0.15)}
.testimonial-card:hover::before{opacity:1}
.stars{display:flex;gap:3px;margin-bottom:1rem;transition:transform 0.38s var(--ease-premium),filter 0.35s ease}
.testimonial-card:hover .stars{transform:translateY(-2px) scale(1.04);filter:drop-shadow(0 5px 12px rgba(245,158,11,0.22))}
.star{color:var(--gold);font-size:0.85rem}
.testimonial-text{font-size:0.9rem;color:var(--muted);line-height:1.8;margin-bottom:1.5rem;font-style:italic;position:relative;transition:color 0.35s ease}
.testimonial-card:hover .testimonial-text{color:#476983}
.testimonial-author{display:flex;align-items:center;gap:0.8rem}
.author-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent3));display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:800;font-size:0.85rem;color:white;flex-shrink:0;transition:transform 0.38s var(--ease-premium),box-shadow 0.35s ease}
.testimonial-card:hover .author-avatar{transform:scale(1.08);box-shadow:0 10px 24px rgba(21,101,192,0.22)}
.author-name{font-weight:700;font-size:0.85rem;color:var(--white)}
.author-loc{font-size:0.75rem;color:var(--muted)}

/* BOOKING */
.booking-bg{background:#0d47a1;background:linear-gradient(145deg,#0d47a1 0%,#1565c0 42%,#1976d2 100%);overflow:hidden}
.booking-bg::before{content:'';position:absolute;inset:0;background:linear-gradient(110deg,rgba(255,255,255,0.1),transparent 28%,rgba(255,255,255,0.045) 62%,transparent);opacity:0.72;pointer-events:none}
.booking-wrap{display:grid;grid-template-columns:1fr 1.5fr;gap:5rem;align-items:start}
.booking-info{position:relative;padding:2.6rem;border:1px solid rgba(255,255,255,0.18);border-radius:28px;background:linear-gradient(145deg,rgba(255,255,255,0.16),rgba(255,255,255,0.055));box-shadow:0 24px 70px rgba(3,35,82,0.22),inset 0 1px 0 rgba(255,255,255,0.16);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);overflow:hidden;transition:transform 0.45s var(--ease-premium),box-shadow 0.4s ease,border-color 0.35s ease}
.booking-info::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.74),transparent)}
.booking-info::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.12),transparent 46%);opacity:0;transition:opacity 0.4s ease;pointer-events:none}
.booking-info:hover{transform:translateY(-6px);border-color:rgba(255,255,255,0.28);box-shadow:0 30px 86px rgba(3,35,82,0.3),inset 0 1px 0 rgba(255,255,255,0.22)}
.booking-info:hover::after{opacity:1}
.booking-bg .section-eyebrow{color:rgba(255,255,255,0.72);margin-bottom:1.2rem}
.booking-bg .section-eyebrow::before{background:rgba(144,202,249,0.82)}
.booking-bg .section-sub{color:rgba(255,255,255,0.78);font-size:0.98rem;line-height:1.85}
.booking-highlight{font-family:var(--font-head);font-size:clamp(2rem,3.6vw,3rem);font-weight:900;letter-spacing:-0.035em;line-height:1.02;margin:1rem 0 1.2rem;color:#fff;text-wrap:balance}
.booking-points{list-style:none;display:flex;flex-direction:column;gap:0.75rem;margin-top:2rem}
.booking-point{display:flex;align-items:center;gap:0.85rem;font-size:0.9rem;font-weight:650;color:rgba(255,255,255,0.88);padding:0.82rem 0.95rem;border:1px solid rgba(255,255,255,0.1);border-radius:14px;background:rgba(255,255,255,0.075);transition:transform 0.35s var(--ease-premium),background 0.35s ease,color 0.35s ease,border-color 0.35s ease,box-shadow 0.35s ease}
.booking-point::before{content:'✓';width:22px;height:22px;border-radius:50%;background:rgba(144,202,249,0.18);border:1px solid rgba(144,202,249,0.36);display:inline-flex;align-items:center;justify-content:center;color:#dff1ff;font-size:0.76rem;font-weight:900;line-height:1;flex-shrink:0;box-shadow:0 0 18px rgba(144,202,249,0.18);transition:transform 0.35s var(--ease-premium),box-shadow 0.35s ease,background 0.35s ease,border-color 0.35s ease}
.booking-point:hover{transform:translateX(7px);background:rgba(255,255,255,0.13);border-color:rgba(255,255,255,0.22);box-shadow:0 14px 32px rgba(3,35,82,0.14);color:#fff}
.booking-point:hover::before{transform:scale(1.12);background:rgba(144,202,249,0.28);border-color:rgba(144,202,249,0.58);box-shadow:0 0 22px rgba(144,202,249,0.42)}
