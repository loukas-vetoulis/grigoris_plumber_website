.map-info-item::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(21,101,192,0.07),transparent 50%);opacity:0;transition:opacity 0.35s ease;pointer-events:none}
.map-info-item:hover{border-color:var(--accent);transform:translateY(-6px);box-shadow:0 14px 36px rgba(21,101,192,0.14);background:#fff}
.map-info-item:hover::before{opacity:1}
.map-icon{font-size:1.3rem;flex-shrink:0;margin-top:0.1rem;transition:transform 0.4s var(--ease-premium),filter 0.35s ease}
.map-info-item:hover .map-icon{transform:translateY(-2px) scale(1.12);filter:drop-shadow(0 8px 14px rgba(21,101,192,0.18))}
.map-info-label{font-size:0.72rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.3rem;transition:color 0.3s ease}
.map-info-item:hover .map-info-label{color:var(--accent)}
.map-info-val{font-size:0.88rem;font-weight:600;color:var(--white)}

/* FOOTER CTA */
.footer-cta{background:linear-gradient(160deg,#1565c0 0%,#0d47a1 100%);border-top:none;text-align:center;padding:7rem 4rem}
.footer-cta h2{font-family:var(--font-head);font-size:clamp(2rem,5vw,3.8rem);font-weight:900;letter-spacing:-0.03em;margin-bottom:1rem;color:#fff}
.footer-cta h2 em{font-style:normal;color:var(--accent-light)}
.footer-cta p{color:rgba(255,255,255,0.75);font-size:1rem;max-width:480px;margin:0 auto 2.5rem;line-height:1.85}
.cta-actions{display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap}
.phone-link{display:flex;align-items:center;gap:0.6rem;font-family:var(--font-head);font-size:1.3rem;font-weight:800;color:#fff;text-decoration:none;transition:transform 0.42s var(--ease-premium),color 0.3s ease,background 0.35s ease,box-shadow 0.35s ease,border-color 0.35s ease;background:rgba(255,255,255,0.12);padding:0.7rem 1.5rem;border-radius:50px;border:1px solid rgba(255,255,255,0.25);position:relative;overflow:hidden}
.phone-link::after{content:'';position:absolute;inset:0;background:linear-gradient(120deg,transparent,rgba(255,255,255,0.16),transparent);transform:translateX(-100%);transition:transform 0.65s var(--ease-premium)}
.phone-link:hover{color:#fff;background:rgba(255,255,255,0.2);border-color:rgba(255,255,255,0.42);transform:translateY(-4px);box-shadow:0 16px 42px rgba(0,0,0,0.18)}
.phone-link:hover::after{transform:translateX(100%)}
footer{background:var(--white);border-top:1px solid var(--border);padding:2rem 4rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;background:#1a2744}
footer p{font-size:0.78rem;color:var(--muted2)}
.footer-links{display:flex;gap:1.5rem}
.footer-links a{font-size:0.78rem;color:var(--muted2);text-decoration:none;transition:color 0.3s ease,transform 0.35s var(--ease-premium);position:relative;padding-bottom:0.25rem}
.footer-links a::after{content:'';position:absolute;left:0;bottom:0;width:100%;height:1px;background:var(--accent-light);transform:scaleX(0);transform-origin:right;transition:transform 0.35s var(--ease-premium)}
.footer-links a:hover{color:var(--accent-light);transform:translateY(-2px)}
.footer-links a:hover::after{transform:scaleX(1);transform-origin:left}

/* STICKY CONVERSION */
.sticky-cta{position:fixed;right:1.4rem;bottom:1.4rem;z-index:120;display:flex;align-items:center;gap:0.8rem;padding:0.7rem 0.75rem 0.7rem 1.05rem;border-radius:999px;border:1px solid rgba(21,101,192,0.16);background:rgba(255,255,255,0.88);box-shadow:0 18px 54px rgba(21,101,192,0.18);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);opacity:0;transform:translateY(24px) scale(0.96);pointer-events:none;transition:opacity 0.35s ease,transform 0.45s var(--ease-premium),box-shadow 0.35s ease}
.sticky-cta.visible{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}
.sticky-cta:hover{box-shadow:0 24px 68px rgba(21,101,192,0.24);transform:translateY(-4px) scale(1)}
.sticky-cta-text{display:flex;flex-direction:column;line-height:1.1}
.sticky-cta-text strong{font-family:var(--font-head);font-size:0.88rem;color:var(--white)}
.sticky-cta-text span{font-size:0.7rem;color:var(--muted);margin-top:0.2rem}
.sticky-cta-actions{display:flex;gap:0.45rem}
.sticky-cta-actions a,.sticky-cta-actions button{width:42px;height:42px;border-radius:50%;border:none;display:flex;align-items:center;justify-content:center;text-decoration:none;background:var(--accent);color:#fff;cursor:none;box-shadow:0 8px 22px rgba(21,101,192,0.28);transition:transform 0.35s var(--ease-premium),background 0.3s ease}
