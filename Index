<script>
// ── CURSOR ──
const cursor=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px'});
function animRing(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing)}animRing();
document.querySelectorAll('button,a,.service-card,.testimonial-card,.map-info-item,.pipe-node,.cert-badge,.process-step,.trust-item,.stat-item,.booking-point,.booking-info,.booking-emergency-card,.booking-form,.map-container,.about-card,.form-input,.form-select,.form-textarea').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cursor.style.width='20px';cursor.style.height='20px';ring.style.width='60px';ring.style.height='60px'});
  el.addEventListener('mouseleave',()=>{cursor.style.width='12px';cursor.style.height='12px';ring.style.width='40px';ring.style.height='40px'});
});

// ── SMART BOOKING CHOICES ──
document.querySelectorAll('.choice-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll(`.choice-btn[data-choice-group="${btn.dataset.choiceGroup}"]`).forEach(item=>item.classList.remove('active'));
    btn.classList.add('active');
    const target=btn.dataset.target?document.getElementById(btn.dataset.target):null;
    if(target&&btn.dataset.value){
      [...target.options].forEach(option=>{
        if(option.textContent.trim()===btn.dataset.value||option.getAttribute('data-gr')===btn.dataset.value){
          target.value=option.value||option.textContent;
        }
      });
    }
  });
});

// ── HEADER SCROLL ──
window.addEventListener('scroll',()=>{
  document.getElementById('header').classList.toggle('scrolled',window.scrollY>80);
  const showCta=window.scrollY>520;
  document.getElementById('sticky-cta')?.classList.toggle('visible',showCta);
  document.getElementById('mobile-action-bar')?.classList.toggle('visible',showCta);
  const maxScroll=document.documentElement.scrollHeight-window.innerHeight;
  const progress=maxScroll>0?(window.scrollY/maxScroll)*100:0;
  document.getElementById('scroll-progress').style.width=progress+'%';
});

// ── STATUS BADGE ──
function updateStatus(){
  const now=new Date();
  const day=now.getDay();const h=now.getHours();const m=now.getMinutes();
  const t=h*60+m;
  const open=(day>=1&&day<=5&&t>=480&&t<1200)||(day===6&&t>=540&&t<1020);
  const dot=document.getElementById('status-dot'),txt=document.getElementById('status-text'),badge=document.getElementById('status-badge');
  const lang=document.querySelector('.lang-btn.active').id==='lang-gr'?'gr':'en';
  if(open){
    dot.className='status-dot open';txt.className='status-text open';
    txt.textContent=lang==='gr'?'Ανοιχτά Τώρα':'Open Now';
    badge.style.borderColor='rgba(34,197,94,0.3)';badge.style.background='rgba(34,197,94,0.05)';
  }else{
    dot.className='status-dot closed';txt.className='status-text closed';
    txt.textContent=lang==='gr'?'Κλειστά':'Closed';
    badge.style.borderColor='rgba(239,68,68,0.3)';badge.style.background='rgba(239,68,68,0.05)';
  }
}
updateStatus();setInterval(updateStatus,30000);

// ── LANGUAGE TOGGLE ──
let currentLang='gr';
function setLang(lang){
  currentLang=lang;
  document.getElementById('lang-gr').classList.toggle('active',lang==='gr');
  document.getElementById('lang-en').classList.toggle('active',lang==='en');
  document.documentElement.lang=lang==='gr'?'el':'en';
  document.querySelectorAll('[data-gr],[data-en]').forEach(el=>{
    const txt=el.getAttribute('data-'+lang);
    if(!txt)return;
    if(el.tagName==='INPUT'||el.tagName==='TEXTAREA'){el.placeholder=txt}
    else if(el.tagName==='BUTTON'||el.tagName==='A'||el.tagName==='DIV'||el.tagName==='P'||el.tagName==='H1'||el.tagName==='H2'||el.tagName==='LI'||el.tagName==='SPAN'||el.tagName==='LABEL'||el.tagName==='STRONG'){el.innerHTML=txt}
    else{el.textContent=txt}
  });
  document.querySelectorAll('option[data-gr]').forEach(el=>{el.textContent=el.getAttribute('data-'+lang)});
  updateStatus();
}

// ── SCROLL REVEAL ──
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}});
},{threshold:0.15});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));

// ── COUNT UP STATS ──
function countUp(id,target,suffix=''){
  let start=0,dur=2000,startTime=null;
  function step(ts){
    if(!startTime)startTime=ts;
    const p=Math.min((ts-startTime)/dur,1);
    const val=Math.round(p*target);
    document.getElementById(id).textContent=val+(suffix||'');
    if(p<1)requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
const statsObserver=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      countUp('count1',2400,'+');
      countUp('count2',1800,'+');
      countUp('count3',15,'+');
      countUp('count4',45,'');
      statsObserver.disconnect();
    }
  });
},{threshold:0.5});
statsObserver.observe(document.querySelector('.stats-grid'));

// ── BOOKING SUBMIT ──
function submitForm(){
  const btn=document.getElementById('form-btn');
  btn.textContent=currentLang==='gr'?'Αποστολή...' : 'Sending...';
  btn.style.opacity='0.7';
  setTimeout(()=>{
    btn.textContent=currentLang==='gr'?'✓ Το αίτημά σας εστάλη!' : '✓ Request Sent!';
    btn.style.background='#22c55e';
    btn.style.opacity='1';
    setTimeout(()=>{
      btn.textContent=currentLang==='gr'?'Αποστολή Αιτήματος' : 'Send Request';
      btn.style.background='';
    },4000);
  },1200);
}
</script>
