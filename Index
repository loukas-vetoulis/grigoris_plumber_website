.booking-form{background:var(--surface);border:none;border-radius:24px;padding:3rem;position:relative;overflow:hidden;box-shadow:0 16px 64px rgba(13,71,161,0.3);transition:transform 0.45s var(--ease-premium),box-shadow 0.4s ease}
.booking-form::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent3),var(--accent-light))}
.booking-form::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 70% 0%,rgba(66,165,245,0.12),transparent 48%);opacity:0;transition:opacity 0.4s ease;pointer-events:none}
